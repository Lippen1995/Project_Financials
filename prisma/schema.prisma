  updatedAt           DateTime                 @updatedAt
  rawSourceId         String?                  @unique
  company             Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rawSource           ShareholdingRawSource?   @relation(fields: [rawSourceId], references: [id], onDelete: SetNull)
  ownerships          Ownership[]
  graphNodes          ShareholdingGraphNode[]
  graphEdges          ShareholdingGraphEdge[]

  @@unique([companyId, taxYear, sourceSystem])
  @@index([companyId, taxYear])
}

model Shareholder {
  id                 String          @id @default(cuid())
  type               ShareholderType
  name               String
  normalizedName     String
  birthYear          Int?
  postalCode         String?
  postalPlace        String?
  externalIdentifier String?
  fingerprint        String          @unique
  linkedCompanyId    String?
  matchConfidence    Decimal?        @db.Decimal(5, 4)
  rawPayload         Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  linkedCompany      Company?        @relation(fields: [linkedCompanyId], references: [id], onDelete: SetNull)
  ownerships         Ownership[]

  @@index([normalizedName])
  @@index([externalIdentifier])
}

model Ownership {
  id               String               @id @default(cuid())
  snapshotId       String
  companyId        String
  shareholderId    String
  shareClass       String?
  numberOfShares   BigInt
  ownershipPercent Decimal?             @db.Decimal(12, 8)
  ownershipBasis   String?
  dataQualityNote  String?
  isDirect         Boolean              @default(true)
  sourceRowKey     String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  snapshot         ShareholdingSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shareholder      Shareholder          @relation(fields: [shareholderId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, sourceRowKey])
  @@index([snapshotId, ownershipPercent])
}

model ShareholdingImportError {
  id          String                @id @default(cuid())
  rawSourceId String
  stage       String
  rowNumber   Int?
  message     String
  payload     Json?
  createdAt   DateTime              @default(now())
  rawSource   ShareholdingRawSource @relation(fields: [rawSourceId], references: [id], onDelete: Cascade)

  @@index([rawSourceId, stage])
}

model ShareholdingGraphNode {
  id         String                    @id @default(cuid())
  snapshotId String
  nodeKey    String
  type       ShareholdingGraphNodeType
  label      String
  metadata   Json?
  sortOrder  Int                       @default(0)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  snapshot   ShareholdingSnapshot      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, nodeKey])
  @@index([snapshotId, sortOrder])
}

