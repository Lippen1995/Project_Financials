}

model DdRoom {
  id               String               @id @default(cuid())
  workspaceId      String
  primaryCompanyId String
  name             String
  description      String?
  status           DdRoomStatus         @default(ACTIVE)
  archivedAt       DateTime?
  lastActivityAt   DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  primaryCompany   Company              @relation(fields: [primaryCompanyId], references: [id], onDelete: Restrict)
  mandate          DdMandate?
  tasks            DdTask[]
  findings         DdFinding[]
  conclusion       DdConclusion?
  decisionLog      DdDecisionLogEntry[]
  posts            DdPost[]
  commentThreads   DdCommentThread[]

  @@index([workspaceId, status])
  @@index([primaryCompanyId, status])
}

model DdTask {
  id                 String              @id @default(cuid())
  roomId             String
  title              String
  description        String?
  stage              DdTaskStage
  workstream         DdWorkstream?
  status             DdTaskStatus        @default(TODO)
  priority           DdTaskPriority      @default(MEDIUM)
  dueAt              DateTime?
  completedAt        DateTime?
  sortOrder          Int                 @default(0)
  assigneeUserId     String?
  createdByUserId    String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  room               DdRoom              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignee           User?               @relation("DdTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdBy          User                @relation("DdTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  findings           DdFinding[]
  evidenceReferences DdFindingEvidence[]
  commentThreads     DdCommentThread[]

  @@index([roomId, stage, status])
  @@index([assigneeUserId, status])
}

model DdMandate {
  id              String   @id @default(cuid())
  roomId          String   @unique
  investmentCase  String?
  thesis          String?
  valueDrivers    String?
  keyRisks        String?
  timeHorizon     String?
  decisionGoal    String?
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  room            DdRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdBy       User     @relation("DdMandateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  updatedBy       User     @relation("DdMandateUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Cascade)
}

model DdFinding {
  id                   String              @id @default(cuid())
  roomId               String
  taskId               String?
  title                String
  description          String?
  stage                DdTaskStage
  workstream           DdWorkstream
  severity             DdFindingSeverity   @default(MEDIUM)
  status               DdFindingStatus     @default(OPEN)
  impact               DdFindingImpact     @default(NONE)
  recommendedAction    String?
  isBlocking           Boolean             @default(false)
  dueAt                DateTime?
  resolvedAt           DateTime?
  assigneeUserId       String?
  handoffWatchId       String?
  createdByUserId      String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  room                 DdRoom              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  task                 DdTask?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  assignee             User?               @relation("DdFindingAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdBy            User                @relation("DdFindingCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  evidence             DdFindingEvidence[] @relation("FindingEvidence")
  referencedByEvidence DdFindingEvidence[] @relation("FindingReferenceEvidence")
  handoffWatch         WorkspaceWatch?     @relation(fields: [handoffWatchId], references: [id], onDelete: SetNull)
  commentThreads       DdCommentThread[]

  @@index([roomId, stage, workstream])
  @@index([roomId, status, severity])
  @@index([assigneeUserId, status])
}

model DdFindingEvidence {
  id                             String                 @id @default(cuid())
