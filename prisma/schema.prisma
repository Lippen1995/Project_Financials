generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  DISSOLVED
  BANKRUPT
}

enum AddressType {
  BUSINESS
  POSTAL
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELED
}

enum DdRoomStatus {
  ACTIVE
  ARCHIVED
}

enum DdCommentThreadTargetType {
  ROOM_POST
  ANNOUNCEMENT
  FINANCIAL_STATEMENT
}

enum WorkspaceWatchStatus {
  ACTIVE
  ARCHIVED
}

enum WorkspaceNotificationType {
  ANNOUNCEMENT_NEW
  FINANCIAL_STATEMENT_NEW
  COMPANY_STATUS_CHANGED
  DISTRESS_MATCH
}

enum WorkspaceMonitorStatus {
  ACTIVE
  ARCHIVED
}

enum ShareholderType {
  PERSON
  COMPANY
  UNKNOWN
}

enum ShareholdingSourceSystem {
  SKATTEETATEN_CSV
  SKATTEETATEN_API
}

enum ShareholdingImportStatus {
  COMPLETED
  PARTIAL
  FAILED
}

enum ShareholdingGraphNodeType {
  COMPANY
  PERSON
  COMPANY_SHAREHOLDER
  UNKNOWN_SHAREHOLDER
}

model User {
  id                          String                @id @default(cuid())
  name                        String?
  email                       String                @unique
  emailVerified               DateTime?
  passwordHash                String?
  image                       String?
  lastWorkspaceId             String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  accounts                    Account[]
  sessions                    Session[]
  subscription                Subscription?
  lastWorkspace               Workspace?            @relation("LastWorkspace", fields: [lastWorkspaceId], references: [id], onDelete: SetNull)
  personalWorkspace           Workspace?            @relation("PersonalWorkspaceOwner")
  workspaceMemberships        WorkspaceMember[]
  sentWorkspaceInvitations    WorkspaceInvitation[] @relation("WorkspaceInvitationInvitedBy")
  acceptedWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationAcceptedBy")
  ddPosts                     DdPost[]
  ddCommentThreads            DdCommentThread[]     @relation("DdCommentThreadCreatedBy")
  ddComments                  DdComment[]           @relation("DdCommentAuthor")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 String             @default("free")
  status               SubscriptionStatus @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id            String                @id @default(cuid())
  name          String
  type          WorkspaceType
  status        WorkspaceStatus       @default(ACTIVE)
  personalOwnerId String?             @unique
  archivedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  personalOwner User?                 @relation("PersonalWorkspaceOwner", fields: [personalOwnerId], references: [id], onDelete: SetNull)
  lastUsedByUsers User[]              @relation("LastWorkspace")
  members       WorkspaceMember[]
  invitations   WorkspaceInvitation[]
  ddRooms       DdRoom[]
  watches       WorkspaceWatch[]
  notifications WorkspaceNotification[]
  monitors      WorkspaceMonitor[]

  @@index([status, type])
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)
  joinedAt    DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, role])
}

model WorkspaceInvitation {
  id               String                    @id @default(cuid())
  workspaceId      String
  email            String
  role             WorkspaceMemberRole       @default(MEMBER)
  token            String                    @unique
  status           WorkspaceInvitationStatus @default(PENDING)
  expiresAt        DateTime
  respondedAt      DateTime?
  invitedByUserId  String
  acceptedByUserId String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  workspace        Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy        User                      @relation("WorkspaceInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?                     @relation("WorkspaceInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([email, status])
}

model Company {
  id                  String               @id @default(cuid())
  slug                String               @unique
  orgNumber           String               @unique
  name                String
  legalForm           String?
  status              CompanyStatus        @default(ACTIVE)
  registeredAt        DateTime?
  foundedAt           DateTime?
  website             String?
  employeeCount       Int?
  revenue             Int?
  operatingProfit     Int?
  netIncome           Int?
  equity              Int?
  description         String?
  sourceSystem        String
  sourceEntityType    String
  sourceId            String
  fetchedAt           DateTime
  normalizedAt        DateTime
  rawPayload          Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  addresses           Address[]
  roles               Role[]
  financialStatements FinancialStatement[]
  shareholdingSnapshots ShareholdingSnapshot[]
  linkedShareholders  Shareholder[]
  ownerships          Ownership[]
  ddRooms             DdRoom[]
  ddCommentThreads    DdCommentThread[]
  workspaceWatches    WorkspaceWatch[]
  workspaceNotifications WorkspaceNotification[]
  industryCodeId      String?
  industryCode        IndustryCode?        @relation(fields: [industryCodeId], references: [id])

  @@index([name])
  @@index([orgNumber])
  @@index([status])
}

model Person {
  id               String   @id @default(cuid())
  fullName         String
  birthYear        Int?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  roles            Role[]
}

model Role {
  id               String   @id @default(cuid())
  title            String
  isBoardRole      Boolean  @default(false)
  fromDate         DateTime?
  toDate           DateTime?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  companyId        String
  personId         String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person           Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([companyId, title])
}

model FinancialStatement {
  id               String   @id @default(cuid())
  fiscalYear       Int
  currency         String   @default("NOK")
  revenue          Int?
  operatingProfit  Int?
  netIncome        Int?
  equity           Int?
  assets           Int?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ddCommentThreads DdCommentThread[]

  @@unique([companyId, fiscalYear])
  @@index([companyId, fiscalYear])
}

model Address {
  id               String      @id @default(cuid())
  type             AddressType @default(BUSINESS)
  line1            String
  line2            String?
  postalCode       String
  city             String
  region           String?
  country          String      @default("NO")
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([region])
}

model IndustryCode {
  id               String    @id @default(cuid())
  code             String    @unique
  title            String
  description      String?
  level            String?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  companies        Company[]
}

model DdRoom {
  id               String      @id @default(cuid())
  workspaceId      String
  primaryCompanyId String
  name             String
  description      String?
  status           DdRoomStatus @default(ACTIVE)
  archivedAt       DateTime?
  lastActivityAt   DateTime    @default(now())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  primaryCompany   Company     @relation(fields: [primaryCompanyId], references: [id], onDelete: Restrict)
  posts            DdPost[]
  commentThreads   DdCommentThread[]

  @@index([workspaceId, status])
  @@index([primaryCompanyId, status])
}

model DdPost {
  id           String           @id @default(cuid())
  roomId        String
  authorUserId  String
  content       String
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  room          DdRoom          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author        User            @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  commentThreads DdCommentThread[]

  @@index([roomId, createdAt])
  @@index([authorUserId, createdAt])
}

model DdCommentThread {
  id                            String                    @id @default(cuid())
  roomId                        String
  targetType                    DdCommentThreadTargetType
  targetCompanyId               String?
  targetAnnouncementId          String?
  targetAnnouncementSourceId    String?
  targetAnnouncementSourceSystem String?
  targetAnnouncementPublishedAt DateTime?
  targetFinancialStatementId    String?
  targetPostId                  String?
  createdByUserId               String
  createdAt                     DateTime                  @default(now())
  updatedAt                     DateTime                  @updatedAt
  room                          DdRoom                    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  targetCompany                 Company?                  @relation(fields: [targetCompanyId], references: [id], onDelete: SetNull)
  targetFinancialStatement      FinancialStatement?       @relation(fields: [targetFinancialStatementId], references: [id], onDelete: SetNull)
  targetPost                    DdPost?                   @relation(fields: [targetPostId], references: [id], onDelete: SetNull)
  createdBy                     User                      @relation("DdCommentThreadCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  comments                      DdComment[]

  @@index([roomId, targetType])
  @@index([targetCompanyId, targetType])
}

model DdComment {
  id              String      @id @default(cuid())
  threadId         String
  authorUserId     String
  parentCommentId  String?
  content          String
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  thread           DdCommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author           User       @relation("DdCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  parentComment    DdComment? @relation("DdCommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies          DdComment[] @relation("DdCommentReplies")

  @@index([threadId, createdAt])
  @@index([authorUserId, createdAt])
}

model WorkspaceWatch {
  id                      String              @id @default(cuid())
  workspaceId             String
  companyId               String
  status                  WorkspaceWatchStatus @default(ACTIVE)
  watchAnnouncements      Boolean             @default(true)
  watchFinancialStatements Boolean            @default(true)
  watchStatusChanges      Boolean             @default(true)
  archivedAt              DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  workspace               Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company                 Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  notifications           WorkspaceNotification[]

  @@unique([workspaceId, companyId])
  @@index([workspaceId, status])
}

model WorkspaceNotification {
  id         String                    @id @default(cuid())
  workspaceId String
  type       WorkspaceNotificationType
  watchId    String?
  companyId  String?
  dedupeKey  String                    @unique
  title      String
  body       String
  metadata   Json?
  createdAt  DateTime                  @default(now())
  readAt     DateTime?
  workspace  Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  watch      WorkspaceWatch?           @relation(fields: [watchId], references: [id], onDelete: SetNull)
  company    Company?                  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([workspaceId, readAt, createdAt])
  @@index([companyId, type])
}

model WorkspaceMonitor {
  id                 String                @id @default(cuid())
  workspaceId        String
  name               String
  status             WorkspaceMonitorStatus @default(ACTIVE)
  industryCodePrefix String?
  minEmployees       Int?
  maxEmployees       Int?
  minRevenue         Int?
  maxRevenue         Int?
  companyStatus      CompanyStatus?
  minimumDaysInStatus Int?
  unsupportedReason  String?
  archivedAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  workspace          Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model ShareholdingRawSource {
  id                String                   @id @default(cuid())
  companyOrgNumber  String
  taxYear           Int
  sourceSystem      ShareholdingSourceSystem
  sourceKey         String
  checksum          String
  importedAt        DateTime
  rawText           String
  parsedRowCount    Int?
  status            ShareholdingImportStatus @default(COMPLETED)
  sourceMetadata    Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  snapshot          ShareholdingSnapshot?
  validationErrors  ShareholdingImportError[]

  @@unique([companyOrgNumber, taxYear, sourceSystem, checksum])
  @@index([companyOrgNumber, taxYear])
}

model ShareholdingSnapshot {
  id                 String                   @id @default(cuid())
  companyId          String
  taxYear            Int
  totalShares        BigInt?
  sourceSystem       ShareholdingSourceSystem
  sourceImportedAt   DateTime
  shareholderCount   Int                      @default(0)
  latestAvailableYear Int?
  dataQualityNote    String?
  graphVersion       String?
  graphPayload       Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  rawSourceId        String?                  @unique
  company            Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rawSource          ShareholdingRawSource?   @relation(fields: [rawSourceId], references: [id], onDelete: SetNull)
  ownerships         Ownership[]
  graphNodes         ShareholdingGraphNode[]
  graphEdges         ShareholdingGraphEdge[]

  @@unique([companyId, taxYear, sourceSystem])
  @@index([companyId, taxYear])
}

model Shareholder {
  id                 String           @id @default(cuid())
  type               ShareholderType
  name               String
  normalizedName     String
  birthYear          Int?
  postalCode         String?
  postalPlace        String?
  externalIdentifier String?
  fingerprint        String           @unique
  linkedCompanyId    String?
  matchConfidence    Decimal?         @db.Decimal(5, 4)
  rawPayload         Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  linkedCompany      Company?         @relation(fields: [linkedCompanyId], references: [id], onDelete: SetNull)
  ownerships         Ownership[]

  @@index([normalizedName])
  @@index([externalIdentifier])
}

model Ownership {
  id                String             @id @default(cuid())
  snapshotId        String
  companyId         String
  shareholderId     String
  shareClass        String?
  numberOfShares    BigInt
  ownershipPercent  Decimal?           @db.Decimal(12, 8)
  ownershipBasis    String?
  dataQualityNote   String?
  isDirect          Boolean            @default(true)
  sourceRowKey      String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  snapshot          ShareholdingSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shareholder       Shareholder        @relation(fields: [shareholderId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, sourceRowKey])
  @@index([snapshotId, ownershipPercent])
}

model ShareholdingImportError {
  id          String               @id @default(cuid())
  rawSourceId String
  stage       String
  rowNumber   Int?
  message     String
  payload     Json?
  createdAt   DateTime             @default(now())
  rawSource   ShareholdingRawSource @relation(fields: [rawSourceId], references: [id], onDelete: Cascade)

  @@index([rawSourceId, stage])
}

model ShareholdingGraphNode {
  id              String                  @id @default(cuid())
  snapshotId      String
  nodeKey         String
  type            ShareholdingGraphNodeType
  label           String
  metadata        Json?
  sortOrder       Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  snapshot        ShareholdingSnapshot    @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, nodeKey])
  @@index([snapshotId, sortOrder])
}

model ShareholdingGraphEdge {
  id               String                @id @default(cuid())
  snapshotId       String
  edgeKey          String
  sourceNodeKey    String
  targetNodeKey    String
  relationshipType String                @default("OWNS")
  percent          Decimal?              @db.Decimal(12, 8)
  shares           BigInt?
  shareClass       String?
  sortOrder        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  snapshot         ShareholdingSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, edgeKey])
  @@index([snapshotId, sortOrder])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
