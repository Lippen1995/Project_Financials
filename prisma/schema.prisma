generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  DISSOLVED
  BANKRUPT
}

enum AddressType {
  BUSINESS
  POSTAL
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ShareholderType {
  PERSON
  COMPANY
  UNKNOWN
}

enum ShareholdingSourceSystem {
  SKATTEETATEN_CSV
  SKATTEETATEN_API
}

enum ShareholdingImportStatus {
  COMPLETED
  PARTIAL
  FAILED
}

enum ShareholdingGraphNodeType {
  COMPANY
  PERSON
  COMPANY_SHAREHOLDER
  UNKNOWN_SHAREHOLDER
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  passwordHash   String?
  image          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 String             @default("free")
  status               SubscriptionStatus @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id                  String               @id @default(cuid())
  slug                String               @unique
  orgNumber           String               @unique
  name                String
  legalForm           String?
  status              CompanyStatus        @default(ACTIVE)
  registeredAt        DateTime?
  foundedAt           DateTime?
  website             String?
  employeeCount       Int?
  revenue             Int?
  operatingProfit     Int?
  netIncome           Int?
  equity              Int?
  description         String?
  sourceSystem        String
  sourceEntityType    String
  sourceId            String
  fetchedAt           DateTime
  normalizedAt        DateTime
  rawPayload          Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  addresses           Address[]
  roles               Role[]
  financialStatements FinancialStatement[]
  shareholdingSnapshots ShareholdingSnapshot[]
  linkedShareholders  Shareholder[]
  ownerships          Ownership[]
  industryCodeId      String?
  industryCode        IndustryCode?        @relation(fields: [industryCodeId], references: [id])

  @@index([name])
  @@index([orgNumber])
  @@index([status])
}

model Person {
  id               String   @id @default(cuid())
  fullName         String
  birthYear        Int?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  roles            Role[]
}

model Role {
  id               String   @id @default(cuid())
  title            String
  isBoardRole      Boolean  @default(false)
  fromDate         DateTime?
  toDate           DateTime?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  companyId        String
  personId         String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person           Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([companyId, title])
}

model FinancialStatement {
  id               String   @id @default(cuid())
  fiscalYear       Int
  currency         String   @default("NOK")
  revenue          Int?
  operatingProfit  Int?
  netIncome        Int?
  equity           Int?
  assets           Int?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, fiscalYear])
  @@index([companyId, fiscalYear])
}

model Address {
  id               String      @id @default(cuid())
  type             AddressType @default(BUSINESS)
  line1            String
  line2            String?
  postalCode       String
  city             String
  region           String?
  country          String      @default("NO")
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([region])
}

model IndustryCode {
  id               String    @id @default(cuid())
  code             String    @unique
  title            String
  description      String?
  level            String?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  companies        Company[]
}

model ShareholdingRawSource {
  id                String                   @id @default(cuid())
  companyOrgNumber  String
  taxYear           Int
  sourceSystem      ShareholdingSourceSystem
  sourceKey         String
  checksum          String
  importedAt        DateTime
  rawText           String
  parsedRowCount    Int?
  status            ShareholdingImportStatus @default(COMPLETED)
  sourceMetadata    Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  snapshot          ShareholdingSnapshot?
  validationErrors  ShareholdingImportError[]

  @@unique([companyOrgNumber, taxYear, sourceSystem, checksum])
  @@index([companyOrgNumber, taxYear])
}

model ShareholdingSnapshot {
  id                 String                   @id @default(cuid())
  companyId          String
  taxYear            Int
  totalShares        BigInt?
  sourceSystem       ShareholdingSourceSystem
  sourceImportedAt   DateTime
  shareholderCount   Int                      @default(0)
  latestAvailableYear Int?
  dataQualityNote    String?
  graphVersion       String?
  graphPayload       Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  rawSourceId        String?                  @unique
  company            Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rawSource          ShareholdingRawSource?   @relation(fields: [rawSourceId], references: [id], onDelete: SetNull)
  ownerships         Ownership[]
  graphNodes         ShareholdingGraphNode[]
  graphEdges         ShareholdingGraphEdge[]

  @@unique([companyId, taxYear, sourceSystem])
  @@index([companyId, taxYear])
}

model Shareholder {
  id                 String           @id @default(cuid())
  type               ShareholderType
  name               String
  normalizedName     String
  birthYear          Int?
  postalCode         String?
  postalPlace        String?
  externalIdentifier String?
  fingerprint        String           @unique
  linkedCompanyId    String?
  matchConfidence    Decimal?         @db.Decimal(5, 4)
  rawPayload         Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  linkedCompany      Company?         @relation(fields: [linkedCompanyId], references: [id], onDelete: SetNull)
  ownerships         Ownership[]

  @@index([normalizedName])
  @@index([externalIdentifier])
}

model Ownership {
  id                String             @id @default(cuid())
  snapshotId        String
  companyId         String
  shareholderId     String
  shareClass        String?
  numberOfShares    BigInt
  ownershipPercent  Decimal?           @db.Decimal(12, 8)
  ownershipBasis    String?
  dataQualityNote   String?
  isDirect          Boolean            @default(true)
  sourceRowKey      String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  snapshot          ShareholdingSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shareholder       Shareholder        @relation(fields: [shareholderId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, sourceRowKey])
  @@index([snapshotId, ownershipPercent])
}

model ShareholdingImportError {
  id          String               @id @default(cuid())
  rawSourceId String
  stage       String
  rowNumber   Int?
  message     String
  payload     Json?
  createdAt   DateTime             @default(now())
  rawSource   ShareholdingRawSource @relation(fields: [rawSourceId], references: [id], onDelete: Cascade)

  @@index([rawSourceId, stage])
}

model ShareholdingGraphNode {
  id              String                  @id @default(cuid())
  snapshotId      String
  nodeKey         String
  type            ShareholdingGraphNodeType
  label           String
  metadata        Json?
  sortOrder       Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  snapshot        ShareholdingSnapshot    @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, nodeKey])
  @@index([snapshotId, sortOrder])
}

model ShareholdingGraphEdge {
  id               String                @id @default(cuid())
  snapshotId       String
  edgeKey          String
  sourceNodeKey    String
  targetNodeKey    String
  relationshipType String                @default("OWNS")
  percent          Decimal?              @db.Decimal(12, 8)
  shares           BigInt?
  shareClass       String?
  sortOrder        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  snapshot         ShareholdingSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, edgeKey])
  @@index([snapshotId, sortOrder])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
