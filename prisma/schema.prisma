generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  DISSOLVED
  BANKRUPT
}

enum DistressStatus {
  RECONSTRUCTION
  BANKRUPTCY
  LIQUIDATION
  FORCED_PROCESS
  FOREIGN_INSOLVENCY
  OTHER_DISTRESS
}

enum AddressType {
  BUSINESS
  POSTAL
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELED
}

enum DdRoomStatus {
  ACTIVE
  ARCHIVED
}

enum DdTaskStage {
  COLLECTION
  COMPANY_UNDERSTANDING
  MANAGEMENT_OWNERSHIP
  FINANCIAL_REVIEW
  LEGAL_REGULATORY
  RISK_ASSESSMENT
  CONCLUSION
}

enum DdTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum DdTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum DdWorkstream {
  FINANCIAL
  COMMERCIAL
  LEGAL
  OPERATIONAL
  REGULATORY
  ESG
}

enum DdFindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DdFindingStatus {
  OPEN
  IN_REVIEW
  MITIGATED
  ACCEPTED
  CLOSED
}

enum DdFindingImpact {
  NONE
  THESIS_RISK
  VALUATION
  DOWNSIDE
  UPSIDE
  MONITORING
  NO_GO
}

enum DdFindingEvidenceType {
  COMPANY
  ANNOUNCEMENT
  FINANCIAL_STATEMENT
  COMPANY_PROFILE_FIELD
  TASK
  FINDING
  PETROLEUM_ENTITY
  PETROLEUM_EVENT
  PETROLEUM_SERIES
}

enum DdCompanyProfileField {
  STATUS
  LEGAL_FORM
  INDUSTRY_CODE
  EMPLOYEE_COUNT
  REVENUE
  DESCRIPTION
}

enum DdDecisionOutcome {
  INVEST
  INVEST_WITH_CONDITIONS
  WATCH
  PASS
}

enum DdCommentThreadTargetType {
  ROOM_POST
  ANNOUNCEMENT
  FINANCIAL_STATEMENT
  FINDING
  TASK
}

enum WorkspaceWatchStatus {
  ACTIVE
  ARCHIVED
}

enum WorkspaceNotificationType {
  ANNOUNCEMENT_NEW
  FINANCIAL_STATEMENT_NEW
  COMPANY_STATUS_CHANGED
  DISTRESS_MATCH
}

enum WorkspaceMonitorStatus {
  ACTIVE
  ARCHIVED
}

enum ShareholderType {
  PERSON
  COMPANY
  UNKNOWN
}

enum ShareholdingSourceSystem {
  SKATTEETATEN_CSV
  SKATTEETATEN_API
}

enum ShareholdingImportStatus {
  COMPLETED
  PARTIAL
  FAILED
}

enum ShareholdingGraphNodeType {
  COMPANY
  PERSON
  COMPANY_SHAREHOLDER
  UNKNOWN_SHAREHOLDER
}

enum PetroleumEntityType {
  FIELD
  DISCOVERY
  LICENCE
  FACILITY
  TUF
  SURVEY
  WELLBORE
}

enum PetroleumWatchEntityType {
  FIELD
  DISCOVERY
  LICENCE
  FACILITY
  TUF
  OPERATOR
  COMPANY_EXPOSURE
}

model User {
  id                           String                @id @default(cuid())
  name                         String?
  email                        String                @unique
  emailVerified                DateTime?
  passwordHash                 String?
  image                        String?
  lastWorkspaceId              String?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  accounts                     Account[]
  sessions                     Session[]
  subscription                 Subscription?
  lastWorkspace                Workspace?            @relation("LastWorkspace", fields: [lastWorkspaceId], references: [id], onDelete: SetNull)
  personalWorkspace            Workspace?            @relation("PersonalWorkspaceOwner")
  workspaceMemberships         WorkspaceMember[]
  sentWorkspaceInvitations     WorkspaceInvitation[] @relation("WorkspaceInvitationInvitedBy")
  acceptedWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationAcceptedBy")
  ddPosts                      DdPost[]
  assignedDdTasks              DdTask[]              @relation("DdTaskAssignee")
  createdDdTasks               DdTask[]              @relation("DdTaskCreatedBy")
  createdDdMandates            DdMandate[]           @relation("DdMandateCreatedBy")
  updatedDdMandates            DdMandate[]           @relation("DdMandateUpdatedBy")
  assignedDdFindings           DdFinding[]           @relation("DdFindingAssignee")
  createdDdFindings            DdFinding[]           @relation("DdFindingCreatedBy")
  createdDdFindingEvidence     DdFindingEvidence[]   @relation("DdFindingEvidenceCreatedBy")
  createdDdConclusions         DdConclusion[]        @relation("DdConclusionCreatedBy")
  updatedDdConclusions         DdConclusion[]        @relation("DdConclusionUpdatedBy")
  ddDecisionLogEntries         DdDecisionLogEntry[]  @relation("DdDecisionLogEntryCreatedBy")
  ddCommentThreads             DdCommentThread[]     @relation("DdCommentThreadCreatedBy")
  ddComments                   DdComment[]           @relation("DdCommentAuthor")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 String             @default("free")
  status               SubscriptionStatus @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id               String                    @id @default(cuid())
  name             String
  type             WorkspaceType
  status           WorkspaceStatus           @default(ACTIVE)
  personalOwnerId  String?                   @unique
  archivedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  personalOwner    User?                     @relation("PersonalWorkspaceOwner", fields: [personalOwnerId], references: [id], onDelete: SetNull)
  lastUsedByUsers  User[]                    @relation("LastWorkspace")
  members          WorkspaceMember[]
  invitations      WorkspaceInvitation[]
  ddRooms          DdRoom[]
  watches          WorkspaceWatch[]
  petroleumWatches PetroleumWorkspaceWatch[]
  notifications    WorkspaceNotification[]
  monitors         WorkspaceMonitor[]

  @@index([status, type])
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)
  joinedAt    DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, role])
}

model WorkspaceInvitation {
  id               String                    @id @default(cuid())
  workspaceId      String
  email            String
  role             WorkspaceMemberRole       @default(MEMBER)
  token            String                    @unique
  status           WorkspaceInvitationStatus @default(PENDING)
  expiresAt        DateTime
  respondedAt      DateTime?
  invitedByUserId  String
  acceptedByUserId String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  workspace        Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy        User                      @relation("WorkspaceInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?                     @relation("WorkspaceInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([email, status])
}

model Company {
  id                        String                            @id @default(cuid())
  slug                      String                            @unique
  orgNumber                 String                            @unique
  name                      String
  legalForm                 String?
  status                    CompanyStatus                     @default(ACTIVE)
  statusObservedAt          DateTime?
  registeredAt              DateTime?
  foundedAt                 DateTime?
  website                   String?
  employeeCount             Int?
  revenue                   Int?
  operatingProfit           Int?
  netIncome                 Int?
  equity                    Int?
  description               String?
  sourceSystem              String
  sourceEntityType          String
  sourceId                  String
  fetchedAt                 DateTime
  normalizedAt              DateTime
  rawPayload                Json?
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt
  addresses                 Address[]
  roles                     Role[]
  financialStatements       FinancialStatement[]
  shareholdingSnapshots     ShareholdingSnapshot[]
  linkedShareholders        Shareholder[]
  ownerships                Ownership[]
  ddRooms                   DdRoom[]
  ddCommentThreads          DdCommentThread[]
  ddFindingEvidence         DdFindingEvidence[]
  workspaceWatches          WorkspaceWatch[]
  petroleumWatches          PetroleumWorkspaceWatch[]
  workspaceNotifications    WorkspaceNotification[]
  distressProfile           CompanyDistressProfile?
  distressFinancialSnapshot DistressFinancialSnapshot?
  petroleumExposureSnapshot PetroleumCompanyExposureSnapshot?
  industryCodeId            String?
  industryCode              IndustryCode?                     @relation(fields: [industryCodeId], references: [id])

  @@index([name])
  @@index([orgNumber])
  @@index([status])
}

model CompanyDistressProfile {
  id                          String         @id @default(cuid())
  companyId                   String         @unique
  distressStatus              DistressStatus
  statusStartedAt             DateTime?
  statusObservedAt            DateTime
  daysInStatus                Int?
  bankruptcyDate              DateTime?
  liquidationDate             DateTime?
  forcedProcessDate           DateTime?
  reconstructionDate          DateTime?
  foreignInsolvencyDate       DateTime?
  lastAnnouncementPublishedAt DateTime?
  lastAnnouncementTitle       String?
  sourceSystem                String
  sourceEntityType            String
  sourceId                    String
  fetchedAt                   DateTime
  normalizedAt                DateTime
  rawPayload                  Json?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  company                     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([distressStatus, daysInStatus])
  @@index([statusStartedAt])
}

model DistressFinancialSnapshot {
  id                  String         @id @default(cuid())
  companyId           String         @unique
  distressStatus      DistressStatus
  daysInStatus        Int?
  industryCode        String?
  sectorCode          String?
  sectorLabel         String?
  lastReportedYear    Int?
  revenue             Int?
  ebit                Int?
  netIncome           Int?
  equityRatio         Decimal?       @db.Decimal(8, 2)
  assets              Int?
  interestBearingDebt Int?
  distressScore       Int?
  scoreVersion        String?
  dataCoverage        String?
  sourceSystem        String?
  sourceEntityType    String?
  sourceId            String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([distressStatus, daysInStatus])
  @@index([sectorCode, lastReportedYear])
}

model DistressSyncState {
  id              String    @id @default(cuid())
  key             String    @unique
  lastUpdateId    Int?
  lastRunAt       DateTime?
  lastBootstrapAt DateTime?
  etag            String?
  lastModified    String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Person {
  id               String   @id @default(cuid())
  fullName         String
  birthYear        Int?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  roles            Role[]
}

model Role {
  id               String    @id @default(cuid())
  title            String
  isBoardRole      Boolean   @default(false)
  fromDate         DateTime?
  toDate           DateTime?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  companyId        String
  personId         String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person           Person    @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([companyId, title])
}

model FinancialStatement {
  id                String              @id @default(cuid())
  fiscalYear        Int
  currency          String              @default("NOK")
  revenue           Int?
  operatingProfit   Int?
  netIncome         Int?
  equity            Int?
  assets            Int?
  sourceSystem      String
  sourceEntityType  String
  sourceId          String
  fetchedAt         DateTime
  normalizedAt      DateTime
  rawPayload        Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ddCommentThreads  DdCommentThread[]
  ddFindingEvidence DdFindingEvidence[]

  @@unique([companyId, fiscalYear])
  @@index([companyId, fiscalYear])
}

model Address {
  id               String      @id @default(cuid())
  type             AddressType @default(BUSINESS)
  line1            String
  line2            String?
  postalCode       String
  city             String
  region           String?
  country          String      @default("NO")
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([region])
}

model PetroleumSyncState {
  key           String    @id
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  status        String?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PetroleumCompanyLink {
  id                     String   @id @default(cuid())
  npdCompanyId           Int      @unique
  companyName            String
  orgNumber              String?
  factPageUrl            String?
  activeOnNcsCurrent     Boolean?
  activeOnNcsFormer      Boolean?
  licenceOperatorCurrent Boolean?
  licenceLicenseeCurrent Boolean?
  tufOperatorCurrent     Boolean?
  tufPartnerCurrent      Boolean?
  linkedCompanyOrgNumber String?
  linkedCompanySlug      String?
  sourceSystem           String
  sourceEntityType       String
  sourceId               String
  fetchedAt              DateTime
  normalizedAt           DateTime
  rawPayload             Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([orgNumber])
  @@index([linkedCompanyOrgNumber])
}

model PetroleumField {
  id                    String   @id @default(cuid())
  npdId                 Int      @unique
  slug                  String   @unique
  name                  String
  activityStatus        String?
  discoveryYear         Int?
  ownerKind             String?
  ownerName             String?
  operatorCompanyName   String?
  operatorNpdCompanyId  Int?
  operatorOrgNumber     String?
  operatorCompanySlug   String?
  mainSupplyBase        String?
  hydrocarbonType       String?
  mainArea              String?
  discoveryWellboreName String?
  factPageUrl           String?
  factMapUrl            String?
  geometry              Json?
  bbox                  Json?
  centroid              Json?
  operatorHistory       Json?
  licensees             Json?
  ownerHistory          Json?
  sourceSystem          String
  sourceEntityType      String
  sourceId              String
  fetchedAt             DateTime
  normalizedAt          DateTime
  rawPayload            Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([activityStatus])
  @@index([mainArea])
  @@index([operatorNpdCompanyId])
}

model PetroleumDiscovery {
  id                   String   @id @default(cuid())
  npdId                Int      @unique
  slug                 String   @unique
  name                 String
  activityStatus       String?
  discoveryYear        Int?
  ownerKind            String?
  ownerName            String?
  operatorCompanyName  String?
  operatorNpdCompanyId Int?
  operatorOrgNumber    String?
  operatorCompanySlug  String?
  hydrocarbonType      String?
  areaName             String?
  relatedFieldName     String?
  relatedFieldNpdId    Int?
  factPageUrl          String?
  factMapUrl           String?
  geometry             Json?
  bbox                 Json?
  centroid             Json?
  operatorHistory      Json?
  sourceSystem         String
  sourceEntityType     String
  sourceId             String
  fetchedAt            DateTime
  normalizedAt         DateTime
  rawPayload           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([activityStatus])
  @@index([areaName])
  @@index([operatorNpdCompanyId])
}

model PetroleumLicence {
  id                    String    @id @default(cuid())
  npdId                 Int       @unique
  slug                  String    @unique
  name                  String
  licensingActivityName String?
  status                String?
  active                Boolean?
  stratigraphical       String?
  currentPhase          String?
  mainArea              String?
  operatorCompanyName   String?
  operatorNpdCompanyId  Int?
  operatorOrgNumber     String?
  operatorCompanySlug   String?
  grantedAt             DateTime?
  validTo               DateTime?
  originalAreaSqKm      Float?
  currentAreaSqKm       Float?
  factPageUrl           String?
  factMapUrl            String?
  geometry              Json?
  bbox                  Json?
  centroid              Json?
  licensees             Json?
  transfers             Json?
  registerMessages      Json?
  sourceSystem          String
  sourceEntityType      String
  sourceId              String
  fetchedAt             DateTime
  normalizedAt          DateTime
  rawPayload            Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
  @@index([mainArea])
  @@index([operatorNpdCompanyId])
}

model PetroleumFacility {
  id                       String    @id @default(cuid())
  npdId                    Int       @unique
  slug                     String    @unique
  name                     String
  fixedOrMoveable          String?
  kind                     String?
  phase                    String?
  functions                String?
  waterDepth               Float?
  designLifetime           Int?
  startupDate              DateTime?
  belongsToName            String?
  belongsToKind            String?
  currentOperatorName      String?
  currentOperatorNpdId     Int?
  currentOperatorOrgNumber String?
  currentOperatorSlug      String?
  factPageUrl              String?
  factMapUrl               String?
  geometry                 Json?
  bbox                     Json?
  centroid                 Json?
  sourceSystem             String
  sourceEntityType         String
  sourceId                 String
  fetchedAt                DateTime
  normalizedAt             DateTime
  rawPayload               Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([phase])
  @@index([belongsToName])
  @@index([currentOperatorNpdId])
}

model PetroleumTuf {
  id                   String   @id @default(cuid())
  npdId                Int      @unique
  slug                 String   @unique
  name                 String
  currentPhase         String?
  mainGroupingName     String?
  medium               String?
  belongsToName        String?
  belongsToNpdId       Int?
  operatorCompanyName  String?
  operatorNpdCompanyId Int?
  operatorOrgNumber    String?
  operatorCompanySlug  String?
  fromFacilityName     String?
  toFacilityName       String?
  dimensionInch        Float?
  waterDepth           Float?
  factPageUrl          String?
  factMapUrl           String?
  geometry             Json?
  bbox                 Json?
  centroid             Json?
  sourceSystem         String
  sourceEntityType     String
  sourceId             String
  fetchedAt            DateTime
  normalizedAt         DateTime
  rawPayload           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([currentPhase])
  @@index([operatorNpdCompanyId])
}

model PetroleumSurvey {
  id               String    @id @default(cuid())
  npdId            Int       @unique
  slug             String    @unique
  name             String
  status           String?
  category         String?
  mainType         String?
  subType          String?
  geographicalArea String?
  companyName      String?
  companyNpdId     Int?
  startedAt        DateTime?
  finalizedAt      DateTime?
  plannedFromDate  DateTime?
  plannedToDate    DateTime?
  factPageUrl      String?
  geometry         Json?
  bbox             Json?
  centroid         Json?
  sourceSystem     String
  sourceEntityType String
  sourceId         String
  fetchedAt        DateTime
  normalizedAt     DateTime
  rawPayload       Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([mainType])
  @@index([companyNpdId])
}

model PetroleumWellbore {
  id                           String    @id @default(cuid())
  npdId                        Int       @unique
  slug                         String    @unique
  name                         String
  wellName                     String?
  drillingOperatorName         String?
  drillingOperatorNpdCompanyId Int?
  drillingOperatorOrgNumber    String?
  drillingOperatorSlug         String?
  productionLicence            String?
  purpose                      String?
  status                       String?
  content                      String?
  wellType                     String?
  entryDate                    DateTime?
  completionDate               DateTime?
  fieldName                    String?
  discoveryName                String?
  drillPermit                  String?
  totalDepth                   Float?
  finalVerticalDepth           Float?
  waterDepth                   Float?
  mainArea                     String?
  drillingFacility             String?
  productionFacility           String?
  licensingActivity            String?
  factPageUrl                  String?
  geometry                     Json?
  bbox                         Json?
  centroid                     Json?
  sourceSystem                 String
  sourceEntityType             String
  sourceId                     String
  fetchedAt                    DateTime
  normalizedAt                 DateTime
  rawPayload                   Json?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([status])
  @@index([purpose])
  @@index([mainArea])
  @@index([drillingOperatorNpdCompanyId])
}

model PetroleumProductionPoint {
  id                   String              @id @default(cuid())
  entityType           PetroleumEntityType
  entityNpdId          Int
  entityName           String
  year                 Int
  month                Int?
  period               String?
  oilNetMillSm3        Float?
  gasNetBillSm3        Float?
  condensateNetMillSm3 Float?
  nglNetMillSm3        Float?
  oeNetMillSm3         Float?
  producedWaterMillSm3 Float?
  investmentsMillNok   Float?
  sourceSystem         String
  sourceEntityType     String
  sourceId             String
  fetchedAt            DateTime
  normalizedAt         DateTime
  rawPayload           Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([entityType, entityNpdId, year, month])
  @@index([entityType, entityNpdId, period, year, month])
  @@index([entityType, year])
}

model PetroleumReserveSnapshot {
  id                    String              @id @default(cuid())
  entityType            PetroleumEntityType
  entityNpdId           Int
  entityName            String
  updatedAtSource       DateTime?
  recoverableOil        Float?
  recoverableGas        Float?
  recoverableNgl        Float?
  recoverableCondensate Float?
  recoverableOe         Float?
  remainingOil          Float?
  remainingGas          Float?
  remainingNgl          Float?
  remainingCondensate   Float?
  remainingOe           Float?
  sourceSystem          String
  sourceEntityType      String
  sourceId              String
  fetchedAt             DateTime
  normalizedAt          DateTime
  rawPayload            Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([entityType, entityNpdId])
  @@index([entityType, remainingOe])
}

model PetroleumInvestmentSnapshot {
  id                              String              @id @default(cuid())
  entityType                      PetroleumEntityType
  entityNpdId                     Int
  entityName                      String
  expectedFutureInvestmentMillNok Int?
  fixedYear                       Int?
  sourceSystem                    String
  sourceEntityType                String
  sourceId                        String
  fetchedAt                       DateTime
  normalizedAt                    DateTime
  rawPayload                      Json?
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime            @updatedAt

  @@unique([entityType, entityNpdId])
}

model PetroleumFieldSnapshot {
  id                              String   @id @default(cuid())
  fieldNpdId                      Int      @unique
  fieldSlug                       String   @unique
  name                            String
  area                            String?
  status                          String?
  hcType                          String?
  operatorNpdCompanyId            Int?
  operatorName                    String?
  operatorOrgNumber               String?
  operatorSlug                    String?
  licenseeCompanyIds              Int[]    @default([])
  latestAnnualOe                  Float?
  latestMonthlyOe                 Float?
  latestSelectedProductionOil     Float?
  latestSelectedProductionGas     Float?
  latestSelectedProductionLiquids Float?
  latestSelectedProductionOe      Float?
  remainingOe                     Float?
  recoverableOe                   Float?
  expectedFutureInvestmentNok     BigInt?
  yoyYtdDeltaPercent              Float?
  currentMonthDeltaPercent        Float?
  sourceSystem                    String
  sourceEntityType                String
  sourceId                        String
  computedAt                      DateTime
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  @@index([area])
  @@index([status])
  @@index([hcType])
  @@index([operatorNpdCompanyId])
  @@index([operatorOrgNumber])
  @@index([latestAnnualOe])
}

model PetroleumLicenceSnapshot {
  id                  String   @id @default(cuid())
  licenceNpdId        Int      @unique
  licenceSlug         String   @unique
  name                String
  area                String?
  status              String?
  active              Boolean?
  currentPhase        String?
  operatorNpdCompanyId Int?
  operatorName        String?
  operatorOrgNumber   String?
  operatorSlug        String?
  licenseeCompanyIds  Int[]    @default([])
  currentAreaSqKm     Float?
