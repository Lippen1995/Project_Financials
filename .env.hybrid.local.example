OPENDATALOADER_ENABLED="true"
OPENDATALOADER_MODE="hybrid"
OPENDATALOADER_HYBRID_BACKEND="docling-fast"
OPENDATALOADER_HYBRID_URL="http://localhost:5002"
OPENDATALOADER_DUAL_RUN="true"
OPENDATALOADER_FALLBACK_TO_LEGACY="true"

# Optional Docker/bootstrap overrides
OPENDATALOADER_HYBRID_PORT="5002"
OPENDATALOADER_HYBRID_OCR_LANG="nor,en"
OPENDATALOADER_HYBRID_LOG_LEVEL="info"
OPENDATALOADER_HYBRID_EXTRA_ARGS=""
